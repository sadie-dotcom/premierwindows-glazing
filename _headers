# Cloudflare Pages custom headers
# Docs: https://developers.cloudflare.com/pages/configuration/headers/
# This file is read automatically by Cloudflare Pages at deploy time.

# Sensible security headers for every response
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# Long-lived, immutable caching for fingerprint-free static assets.
# Fonts and images rarely change; cache them hard.
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable

/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS: cache for a day. If you adopt versioned filenames (e.g. main.abc123.css)
# you can safely raise this to a year with `immutable`.
/assets/css/*
  Cache-Control: public, max-age=86400

/assets/js/*
  Cache-Control: public, max-age=86400
